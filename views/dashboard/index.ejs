<%- include('../partials/header', { title: 'Dashboard' }) %>
<%- include('../partials/sidebar') %>

<div class="content">
  <h1 class="mb-4">Dashboard</h1>

  <div class="row g-4">
    <div class="col-md-3">
      <div class="card card-summary">
        <div class="card-body">
          <h6 class="text-muted">Total Pemasukan</h6>
          <h3 class="text-success">
            Rp <%= Number(totalIncome).toLocaleString('id-ID') %>
          </h3>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card card-summary">
        <div class="card-body">
          <h6 class="text-muted">Total Pengeluaran</h6>
          <h3 class="text-danger">
            Rp <%= Number(totalExpense).toLocaleString('id-ID') %>
          </h3>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card card-summary">
        <div class="card-body">
          <h6 class="text-muted">Saldo</h6>
          <h3 class="text-primary">
            Rp <%= Number(balance).toLocaleString('id-ID') %>
          </h3>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card card-summary">
        <div class="card-body">
          <h6 class="text-muted">Jumlah Transaksi</h6>
          <h3><%= totalTransactions %></h3>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>