<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Sistem Pencatatan Keuangan' %></title>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <!-- Bootstrap Icons -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    rel="stylesheet"
  />

  <!-- Google Font -->
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --bg-body: #f5f7fb;
      --bg-sidebar: #198754;
      --bg-card: #ffffff;
      --text-main: #1f2937;
      --text-muted: #6b7280;
      --border-color: #e5e7eb;
      --shadow-soft: 0 10px 30px rgba(15, 23, 42, 0.06);
      --radius-lg: 18px;
      --sidebar-width: 270px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: var(--bg-body);
      color: var(--text-main);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Sidebar desktop */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: var(--sidebar-width);
      height: 100vh;
      background: var(--bg-sidebar);
      color: #fff;
      padding: 24px 18px;
      overflow-y: auto;
      z-index: 1040;
    }

    .sidebar-brand {
      font-size: 1.35rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .sidebar-user {
      font-size: 0.9rem;
      opacity: 0.85;
      margin-bottom: 1rem;
      padding: 10px 12px;
      background: rgba(255,255,255,0.08);
      border-radius: 12px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      color: rgba(255,255,255,0.92);
      text-decoration: none;
      padding: 11px 12px;
      border-radius: 12px;
      margin-bottom: 6px;
      transition: all 0.2s ease;
    }

    .sidebar a:hover {
      background: rgba(255,255,255,0.14);
      color: #fff;
      transform: translateX(2px);
    }

    /* Area konten */
    .content {
        margin-left: var(--sidebar-width);
        min-height: 100vh;
        padding: 24px;
        display: flex;
        flex-direction: column;
    }

    /* Topbar mobile */
    .mobile-topbar {
      display: none;
      background: #ffffff;
      border-bottom: 1px solid var(--border-color);
      padding: 14px 18px;
      position: sticky;
      top: 0;
      z-index: 1030;
    }

    /* Card modern */
    .card {
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-soft);
      overflow: hidden;
    }

    .card-summary {
      border: none;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-soft);
    }

    /* Tombol */
    .btn {
      border-radius: 12px;
      font-weight: 500;
    }

    /* Form */
    .form-control,
    .form-select,
    textarea {
      border-radius: 12px;
      border: 1px solid var(--border-color);
      padding: 0.75rem 0.9rem;
    }

    .form-control:focus,
    .form-select:focus,
    textarea:focus {
      box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.15);
      border-color: #198754;
    }

    /* Table */
    .table {
      margin-bottom: 0;
      vertical-align: middle;
    }

    /* Container section */
    .page-header {
      margin-bottom: 1.5rem;
    }

    .page-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin: 0;
    }

    .page-subtitle {
      color: var(--text-muted);
      margin-top: 4px;
      font-size: 0.95rem;
    }

    /* Responsive */
    @media (max-width: 991.98px) {
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
      }

      .sidebar.show {
        transform: translateX(0);
      }

      .content {
        margin-left: 0;
        padding: 16px;
      }

      .mobile-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .page-title {
        font-size: 1.4rem;
      }
    }

    /* Overlay saat sidebar mobile aktif */
    .sidebar-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.35);
      z-index: 1035;
      display: none;
    }

    .sidebar-overlay.show {
      display: block;
    }

    /* Footer kecil */
    .app-footer {
  margin-top: auto;
  padding-top: 24px;
  color: var(--text-muted);
  font-size: 0.85rem;
  text-align: center;
}
  </style>
</head>
<body>

<!-- Topbar Mobile -->
<div class="mobile-topbar">
  <button class="btn btn-outline-success btn-sm" onclick="toggleSidebar()">
    <i class="bi bi-list"></i>
  </button>
  <strong>Catat Uang</strong>
</div>

<!-- Overlay -->
<div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>