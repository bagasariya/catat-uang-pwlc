<%- include('../partials/header', { title: 'Laporan' }) %>
<%- include('../partials/sidebar') %>

<div class="content">
  <!-- Header -->
  <div class="page-header">
    <h1 class="page-title">Laporan Keuangan</h1>
    <p class="page-subtitle">
      Pilih periode terlebih dahulu untuk menampilkan laporan.
    </p>
  </div>

  <!-- Form Filter -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/reports">
        <div class="row g-3">

          <!-- Bulan -->
          <div class="col-12 col-md-4">
            <label class="form-label">Bulan</label>
            <select name="month" class="form-select">
              <option value="">Semua Bulan</option>
              <option value="01" <%= month === '01' ? 'selected' : '' %>>Januari</option>
              <option value="02" <%= month === '02' ? 'selected' : '' %>>Februari</option>
              <option value="03" <%= month === '03' ? 'selected' : '' %>>Maret</option>
              <option value="04" <%= month === '04' ? 'selected' : '' %>>April</option>
              <option value="05" <%= month === '05' ? 'selected' : '' %>>Mei</option>
              <option value="06" <%= month === '06' ? 'selected' : '' %>>Juni</option>
              <option value="07" <%= month === '07' ? 'selected' : '' %>>Juli</option>
              <option value="08" <%= month === '08' ? 'selected' : '' %>>Agustus</option>
              <option value="09" <%= month === '09' ? 'selected' : '' %>>September</option>
              <option value="10" <%= month === '10' ? 'selected' : '' %>>Oktober</option>
              <option value="11" <%= month === '11' ? 'selected' : '' %>>November</option>
              <option value="12" <%= month === '12' ? 'selected' : '' %>>Desember</option>
            </select>
          </div>

          <!-- Tahun -->
          <div class="col-12 col-md-4">
            <label class="form-label">Tahun</label>
            <select name="year" class="form-select">
              <option value="">Semua Tahun</option>
              <% years.forEach(y => { %>
                <option
                  value="<%= y %>"
                  <%= String(year) === String(y) ? 'selected' : '' %>
                >
                  <%= y %>
                </option>
              <% }) %>
            </select>
          </div>

          <!-- Tombol -->
          <div class="col-12 col-md-4 d-flex align-items-end gap-2">
            <button class="btn btn-primary flex-fill">
              Tampilkan
            </button>

            <a href="/reports" class="btn btn-outline-secondary">
              Reset
            </a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Data Laporan -->
  <% if (showReport) { %>

    <!-- Ringkasan -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-md-3">
        <div class="card card-summary">
          <div class="card-body">
            <small class="text-muted">Jumlah Data</small>
            <h5 class="mb-0"><%= totalData %></h5>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-3">
        <div class="card card-summary">
          <div class="card-body">
            <small class="text-muted">Pemasukan</small>
            <h5 class="text-success mb-0">
              Rp <%= Number(totalIncome).toLocaleString('id-ID') %>
            </h5>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-3">
        <div class="card card-summary">
          <div class="card-body">
            <small class="text-muted">Pengeluaran</small>
            <h5 class="text-danger mb-0">
              Rp <%= Number(totalExpense).toLocaleString('id-ID') %>
            </h5>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-3">
        <div class="card card-summary">
          <div class="card-body">
            <small class="text-muted">Saldo</small>
            <h5 class="text-primary mb-0">
              Rp <%= Number(balance).toLocaleString('id-ID') %>
            </h5>
          </div>
        </div>
      </div>
    </div>
    <!-- Tombol Download -->
<div class="card mb-4">
  <div class="card-body d-flex flex-column flex-md-row gap-2 justify-content-end">
    <a
      href="/reports/export/pdf?month=<%= month || '' %>&year=<%= year || '' %>"
      class="btn btn-danger"
    >
      <i class="bi bi-file-earmark-pdf me-1"></i>
      Download PDF
    </a>

    <a
      href="/reports/export/excel?month=<%= month || '' %>&year=<%= year || '' %>"
      class="btn btn-success"
    >
      <i class="bi bi-file-earmark-excel me-1"></i>
      Download Excel
    </a>
  </div>
</div>
    <!-- Tabel -->
    <div class="card">
      <div class="card-body">
        <h5 class="mb-3">Detail Transaksi</h5>

        <% if (transactions.length === 0) { %>
          <p class="text-muted mb-0">
            Tidak ada data untuk periode yang dipilih.
          </p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr>
                  <th>Tanggal</th>
                  <th>Kategori</th>
                  <th>Jenis</th>
                  <th>Deskripsi</th>
                  <th class="text-end">Nominal</th>
                </tr>
              </thead>
              <tbody>
                <% transactions.forEach(item => { %>
                  <tr>
                    <td><%= item.transaction_date %></td>
                    <td><%= item.categories?.name || '-' %></td>
                    <td>
                      <span class="badge bg-<%= item.categories?.type === 'income' ? 'success' : 'danger' %>">
                        <%= item.categories?.type === 'income' ? 'Pemasukan' : 'Pengeluaran' %>
                      </span>
                    </td>
                    <td><%= item.description || '-' %></td>
                    <td class="text-end fw-semibold">
                      Rp <%= Number(item.amount).toLocaleString('id-ID') %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  <% } %>
</div>

<%- include('../partials/footer') %>